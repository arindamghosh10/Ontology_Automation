# ── REQUIRED ─────────────────────────────────────────────────────────────────

# OpenRouter API key for LLM calls (DeepSeek)
# Get yours at: https://openrouter.ai
OPENROUTER_API_KEY=
# SerpAPI key for Google search (ZoomInfo / D&B / Wikipedia discovery)
# Get yours at: https://serpapi.com  (100 free searches/month on free tier)
SERPAPI_KEY=

# Firecrawl API key for website scraping (handles JS, bot-bypass automatically)
# Get yours at: https://firecrawl.dev  (500 free credits/month on free tier)
FIRECRAWL_API_KEY=

# ── OPTIONAL ──────────────────────────────────────────────────────────────────

# Override the default LLM model (default: deepseek/deepseek-chat)
# OPENROUTER_MODEL=deepseek/deepseek-chat

# Residential proxy for Playwright fallback (only needed without Firecrawl)
# PROXY_URL=http://user:pass@proxy-host:port
# RESIDENTIAL_PROXY_URL=http://user:pass@residential-proxy:port

# CAPTCHA solver (only needed for Playwright fallback)
# CAPTCHA_API_KEY=



Get at: https://console.cloud.google.com  (enable Places API, ~$17/1000 calls)
GOOGLE_PLACES_API_KEY=your-google-places-key-here

# ── OPTIONAL ──────────────────────────────────────────────────────────
# OPENROUTER_MODEL=deepseek/deepseek-chat
